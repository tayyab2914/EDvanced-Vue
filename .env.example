# Database.
#   DATABASE_URL = used by the app at runtime (lib/db.ts, via the `pg` driver adapter)
#   DIRECT_URL   = non-pooled connection used by Prisma Migrate + one-shot scripts.
#                  Optional: falls back to DATABASE_URL when unset (e.g. local Postgres).
#
# Local Postgres:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/k12_finance?schema=public"
#
# Supabase (grab both from Project -> Connect). Use the *transaction* pooler (:6543) for
# runtime and the *session* pooler (:5432) for migrations — migrations cannot run through
# the transaction pooler. Add sslmode=no-verify: Supabase signs with its own CA, so pg's
# default full verification fails. Do NOT add pgbouncer=true (that's for Prisma's engine;
# we use the pg driver adapter).
# DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?sslmode=no-verify"
# DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=no-verify"

# Session signing secret — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET="replace-with-a-32-byte-base64-secret"

# Public base URL for email links (no trailing slash)
APP_URL="http://localhost:3000"

# Initial Platform Admin bootstrap — used by `npm run db:seed`
PLATFORM_ADMIN_EMAIL="admin@example.com"
PLATFORM_ADMIN_PASSWORD="change-me-to-a-strong-password"

# SMTP email. Leave SMTP_HOST blank to log emails to the server console instead of sending.
#   Gmail:    SMTP_HOST=smtp.gmail.com       SMTP_PORT=587   (use a Google "App Password")
#   SendGrid: SMTP_HOST=smtp.sendgrid.net    SMTP_PORT=587   SMTP_USER=apikey  SMTP_PASS=<api-key>
#   Mailtrap: SMTP_HOST=sandbox.smtp.mailtrap.io  SMTP_PORT=2525   (inbox for testing)
# Set SMTP_SECURE="true" only for implicit-TLS port 465 (587/2525 use STARTTLS = "false").
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"
EMAIL_FROM="EDvanced Vue <no-reply@example.com>"
