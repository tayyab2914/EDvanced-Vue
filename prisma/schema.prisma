// K-12 School Finance Platform — data model (Milestone 1: Platform Foundation)
// Two data groups: (1) reference/master data (stable, per-district) and
// (2) periodic snapshot data (uploaded each reporting period).
// M1 builds ONLY the tenancy + auth + audit + master/reference tables below.
//
// DESIGN-FOR-FUTURE (M2/M3 — do not build yet): periodic tables
// (RevenueActual, ExpenditureActual, FundBalance, CashFlow, GrantsActivity,
// CapitalProjectsActivity, Enrollment) plus a DatasetVersion snapshot table
// will each carry districtId + fiscalYear + period/survey + version and FK
// into the master rows below by their stable `id` PKs — inheriting the same
// per-district scoped-client enforcement with no rework.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===================== Enums =====================

enum Role {
  PLATFORM_ADMIN
  DISTRICT_ADMIN
  FINANCE_USER
  VIEWER
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
}

enum DistrictStatus {
  ACTIVE
  INACTIVE
}

enum TokenType {
  INVITE
  PASSWORD_RESET
}

enum GrantStatus {
  PENDING
  ACTIVE
  ON_HOLD
  CLOSE
  CANCELLED
}

enum ProjectStatus {
  PLANNING
  DESIGN
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CLOSED
}

enum ProjectType {
  NEW_CONSTRUCTION
  RENOVATION
  ADDITION
  MAINTENANCE
  TECHNOLOGY
  SAFETY_SECURITY
  OTHER
}

// ===================== Tenancy / Auth / Audit =====================

/// The tenant root. Every tenant-owned row carries `districtId`.
model District {
  id                   String         @id @default(cuid())
  code                 String         @unique
  name                 String
  status               DistrictStatus @default(ACTIVE)
  state                String         @default("FL") // 2-letter US state code
  fiscalYearStartMonth Int            @default(7) // July
  settings             Json           @default("{}")
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  users           User[]
  schools         School[]
  grants          Grant[]
  capitalProjects CapitalProject[]
  funds           Fund[]
  revenueSources  RevenueSource[]
  functions       AccountFunction[]
  objects         AccountObject[]
  auditLogs       AuditLog[]
}

/// districtId is NULL for Platform Admins (cross-district); required for all others (enforced in app logic).
model User {
  id                  String     @id @default(cuid())
  districtId          String?
  role                Role
  email               String     @unique
  name                String
  passwordHash        String? // null until an INVITED user sets their password
  status              UserStatus @default(INVITED)
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  district           District?           @relation(fields: [districtId], references: [id], onDelete: Cascade)
  sessions           Session[]
  verificationTokens VerificationToken[]

  @@index([districtId])
}

/// DB-backed sessions enable revocation and lockout-logout. The cookie carries a signed { sessionId, ... }.
model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  ipAddress String?
  userAgent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// One-time tokens for INVITE (set first password) and PASSWORD_RESET. Only the SHA-256 hash is stored.
model VerificationToken {
  id        String    @id @default(cuid())
  userId    String
  type      TokenType
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Append-only activity trail. districtId is NULL for platform-level events.
model AuditLog {
  id          String   @id @default(cuid())
  districtId  String?
  actorUserId String? // not an FK: retain history even if the user is deleted
  action      String
  entityType  String?
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  district District? @relation(fields: [districtId], references: [id], onDelete: SetNull)

  @@index([districtId, createdAt])
  @@index([actorUserId])
}

// ===================== Master data (tenant-owned) =====================

model School {
  id           String   @id @default(cuid())
  districtId   String
  schoolNumber String
  name         String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  district District @relation(fields: [districtId], references: [id], onDelete: Cascade)

  @@unique([districtId, schoolNumber])
  @@index([districtId])
}

model Grant {
  id            String      @id @default(cuid())
  districtId    String
  grantId       String // "Grant Number"
  name          String // "Grant Name"
  revenueTypeId String?
  awardAmount   Decimal?
  status        GrantStatus @default(PENDING)
  grantPeriod   String? // e.g. "2026-27"
  grantManager  String?
  description   String?
  cfdaNumber    String?
  active        Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  district    District     @relation(fields: [districtId], references: [id], onDelete: Cascade)
  revenueType RevenueType? @relation(fields: [revenueTypeId], references: [id], onDelete: SetNull)

  @@unique([districtId, grantId])
  @@index([districtId])
  @@index([revenueTypeId])
}

model CapitalProject {
  id          String        @id @default(cuid())
  districtId  String
  projectId   String // "Project Number"
  name        String // "Project Name"
  description String?
  status      ProjectStatus @default(PLANNING)
  projectType ProjectType?
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  district District @relation(fields: [districtId], references: [id], onDelete: Cascade)

  @@unique([districtId, projectId])
  @@index([districtId])
}

// ---- District-owned account dimensions (each district uploads/enters its own; no standards) ----

model Fund {
  id         String   @id @default(cuid())
  districtId String
  code       String
  name       String
  fundTypeId String?
  sortOrder  Int?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  district District  @relation(fields: [districtId], references: [id], onDelete: Cascade)
  fundType FundType? @relation(fields: [fundTypeId], references: [id], onDelete: SetNull)

  @@unique([districtId, code])
  @@index([districtId])
  @@index([fundTypeId])
}

model RevenueSource {
  id            String   @id @default(cuid())
  districtId    String
  code          String
  name          String
  revenueTypeId String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  district    District     @relation(fields: [districtId], references: [id], onDelete: Cascade)
  revenueType RevenueType? @relation(fields: [revenueTypeId], references: [id], onDelete: SetNull)

  @@unique([districtId, code])
  @@index([districtId])
  @@index([revenueTypeId])
}

/// "Function" in the chart of accounts. Renamed to avoid the JS `Function` identifier clash.
model AccountFunction {
  id             String   @id @default(cuid())
  districtId     String
  code           String
  name           String
  functionTypeId String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  district     District      @relation(fields: [districtId], references: [id], onDelete: Cascade)
  functionType FunctionType? @relation(fields: [functionTypeId], references: [id], onDelete: SetNull)

  @@unique([districtId, code])
  @@index([districtId])
  @@index([functionTypeId])
  @@map("functions")
}

/// "Object" in the chart of accounts. Renamed to avoid the JS `Object` identifier clash.
model AccountObject {
  id           String   @id @default(cuid())
  districtId   String
  code         String
  name         String
  objectTypeId String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  district   District    @relation(fields: [districtId], references: [id], onDelete: Cascade)
  objectType ObjectType? @relation(fields: [objectTypeId], references: [id], onDelete: SetNull)

  @@unique([districtId, code])
  @@index([districtId])
  @@index([objectTypeId])
  @@map("objects")
}

// ===================== Platform-managed global lookups =====================
// Standardization/roll-up categories owned by EDvanced Vue (Platform Admin), shared
// by every district so cross-district reporting groups consistently. NOT tenant-scoped.

model FundType {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  funds Fund[]
}

model RevenueType {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  revenueSources RevenueSource[]
  grants         Grant[]
}

model ObjectType {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  objects AccountObject[]
}

model FunctionType {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  functions AccountFunction[]
}

model Status {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
